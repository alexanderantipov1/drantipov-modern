# Dr. Antipov Website - Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# Public variables (accessible in browser - prefix with NEXT_PUBLIC_)
NEXT_PUBLIC_SITE_URL="https://drantipov.com"
NEXT_PUBLIC_GA_ID="your_google_analytics_measurement_id"
NEXT_PUBLIC_GTM_ID="your_google_tag_manager_id"

# Server-side only variables (NOT accessible in browser)
RESEND_API_KEY="your_resend_api_key_here"
CONTACT_EMAIL="info@drantipov.com"
ADMIN_EMAIL="office@drantipov.com"

# Calendly (for appointment scheduling)
NEXT_PUBLIC_CALENDLY_URL="https://calendly.com/dr-antipov"

# Optional: CRM integration (HubSpot)
HUBSPOT_WEBHOOK_URL="https://api.hubspot.com/webhooks/your_webhook_id"

# Russian funnel — Salesforce Web-to-Lead (used by /api/lead).
# Required for the /ru lead form to actually post into Salesforce.
# Find your 15- or 18-char org ID under Setup → Company Information → "Salesforce.com Organization ID".
SALESFORCE_ORG_ID=

# Optional: while testing, Salesforce will email a debug receipt for every submission.
# Leave blank in production.
SALESFORCE_DEBUG_EMAIL=

# Russian funnel — site chatbot (used by /api/chat).
# Get a key at https://console.anthropic.com/. Powers the floating Russian-speaking
# AI assistant on /ru pages. Without it, the chat button shows a graceful fallback
# message asking the visitor to call (916) 783-2110 instead.
ANTHROPIC_API_KEY=

# Russian funnel — concierge channel buttons. Leave blank to hide that channel.
# WhatsApp: digits only, country code first (e.g. 19167832110).
NEXT_PUBLIC_CONTACT_WHATSAPP=
# Telegram: username without the @.
NEXT_PUBLIC_CONTACT_TELEGRAM=
